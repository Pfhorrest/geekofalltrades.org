<?xml version="1.0" encoding="UTF-8" ?>
<phpdocumentor
    configVersion="3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://www.phpdoc.org"
>
    <title>PrevHP Documentation</title>
    
    <paths>
        <output>_docs/php</output>
        <cache>.phpdoc/cache</cache>
    </paths>

    <version number="1.0.0">
        <api format="php">
            <source dsn=".">
                <path>___structure</path>
            </source>
        </api>
    </version>

    <setting name="project.name" value="geekofalltrades/prevhp"/>
</phpdocumentor>